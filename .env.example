# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI Embedding
OPENAI_API_KEY=your-openai-api-key

# Metadata Extraction LLM (choose one)
ANTHROPIC_API_KEY=your-anthropic-api-key
# or
# OPENAI_METADATA_API_KEY=your-openai-api-key

# Auth
CAPTURE_WEBHOOK_SECRET=your-256-bit-random-hex
CAPTURE_JWT_SECRET=your-256-bit-random-hex
MCP_CLIENT_SECRET=your-strong-random-secret

# MCP Server
MCP_SERVER_PORT=3001
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Metadata LLM choice: "anthropic" or "openai"
METADATA_LLM_PROVIDER=anthropic
