# =============================================================================
# Open Brain - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env with real credentials.

# -----------------------------------------------------------------------------
# Neon Postgres
# -----------------------------------------------------------------------------
# Pooled connection string from the Neon console (Connection Details).
# Migrations automatically use the direct endpoint (the -pooler suffix is
# stripped by scripts/migrate.sh and the CLI migrations step).
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# LLM API Keys
# -----------------------------------------------------------------------------
# OpenAI key — used for generating text embeddings
OPENAI_API_KEY=your-openai-api-key

# Anthropic key — used for metadata extraction (when METADATA_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: separate OpenAI key for metadata extraction (when METADATA_LLM_PROVIDER=openai).
# Falls back to OPENAI_API_KEY when unset.
OPENAI_METADATA_API_KEY=your-openai-metadata-api-key

# -----------------------------------------------------------------------------
# Auth & Security
# -----------------------------------------------------------------------------
# Secret used to verify incoming capture webhook requests (random 256-bit hex)
CAPTURE_WEBHOOK_SECRET=your-256-bit-random-hex

# Secret used to sign/verify JWTs for the capture endpoint (random 256-bit hex)
CAPTURE_JWT_SECRET=your-256-bit-random-hex

# Shared secret between MCP client and server for authentication
MCP_CLIENT_SECRET=your-strong-random-secret

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
# OpenAI embedding model to use
EMBEDDING_MODEL=text-embedding-3-small

# Dimensions of the embedding vectors (must match the memories.embedding column)
EMBEDDING_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# Metadata Extraction
# -----------------------------------------------------------------------------
# Which LLM provider to use for metadata extraction: "anthropic" or "openai"
METADATA_LLM_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# Deployed Workers (written by `openbrain setup` after wrangler deploy)
# -----------------------------------------------------------------------------
CAPTURE_WORKER_URL=https://open-brain-capture.your-subdomain.workers.dev
MCP_WORKER_URL=https://open-brain-mcp.your-subdomain.workers.dev
