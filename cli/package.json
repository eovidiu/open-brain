{
  "name": "@eovidiu/open-brain-setup",
  "version": "2.0.0",
  "description": "One-command setup for Open Brain — deploy your AI memory to Supabase",
  "type": "module",
  "bin": {
    "open-brain-setup": "./dist/index.js",
    "openbrain": "./dist/index.js"
  },
  "files": [
    "dist",
    "dist/edge-function.ts"
  ],
  "scripts": {
    "build": "tsc && npm run bundle-assets",
    "bundle-assets": "cp ../supabase/functions/open-brain-mcp/index.ts dist/edge-function.ts 2>/dev/null || true",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@supabase/supabase-js": "^2.49.4"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
