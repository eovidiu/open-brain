{
  "name": "@eovidiu/open-brain-setup",
  "version": "2.1.5",
  "description": "One-command setup for Open Brain — deploy your AI memory to Supabase",
  "type": "module",
  "bin": {
    "open-brain-setup": "./dist/index.js",
    "openbrain": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eovidiu/open-brain.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/eovidiu/open-brain#readme",
  "bugs": "https://github.com/eovidiu/open-brain/issues",
  "author": "Ovidiu Eftimie",
  "license": "MIT",
  "keywords": [
    "mcp",
    "open-brain",
    "ai-memory",
    "supabase",
    "knowledge-base",
    "vector-search"
  ],
  "scripts": {
    "build": "tsc && npm run bundle-assets",
    "bundle-assets": "cp ../supabase/functions/open-brain-mcp/index.ts dist/edge-function.ts 2>/dev/null || true",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@supabase/supabase-js": "^2.99.3"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
